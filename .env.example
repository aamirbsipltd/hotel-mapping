# Database — local dev uses SQLite file automatically (no setup needed)
# DATABASE_URL defaults to file:./prisma/dev.db when not set

# Production (Turso — free tier, recommended):
#   1. Sign up at https://turso.tech
#   2. turso db create hotel-mapping
#   3. turso db show hotel-mapping   → copy the URL (libsql://...)
#   4. turso db tokens create hotel-mapping  → copy the auth token
DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=

# Tripadvisor Content API key (required for matching — leave blank for local testing)
# Get yours at: https://developer-tripadvisor.com/content-api/
TRIPADVISOR_API_KEY=

# Stripe (Pro unlock — add later)
# Test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Demo tier row cap (default 5)
DEMO_ROW_LIMIT=5
